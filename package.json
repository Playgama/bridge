{
    "name": "@playgama/bridge",
    "version": "2.0.1",
    "description": "One SDK for cross-platform publishing HTML5 games",
    "main": "dist/playgama-bridge.umd.js",
    "module": "dist/playgama-bridge.esm.js",
    "types": "dist/types/npm.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/npm.d.ts",
            "import": "./dist/playgama-bridge.esm.js",
            "require": "./dist/playgama-bridge.umd.js"
        }
    },
    "files": [
        "dist/playgama-bridge.esm.js",
        "dist/playgama-bridge.umd.js",
        "dist/types",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "npm run build:bundled",
        "build:dynamic": "webpack --config-name dynamic",
        "build:bundled": "webpack --config-name bundled",
        "build:nolint": "webpack --config-name bundled --env noLint",
        "build:platform": "ts-node scripts/build-platform.ts",
        "build:dist": "ts-node scripts/build-dist.ts",
        "build:npm": "webpack --env npm --env noLint",
        "build:types": "tsc -p tsconfig.types.json",
        "build:package": "npm run build:npm && npm run build:types",
        "develop": "webpack --mode=development",
        "dev": "webpack serve --mode=development --config-name dynamic",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ scripts/ webpack.config.ts vitest.config.ts --ext .ts,.tsx",
        "lint:fix": "eslint src/ scripts/ webpack.config.ts vitest.config.ts --ext .ts,.tsx --fix",
        "prepublishOnly": "npm run lint && npm test && npm run build:package"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/playgama/bridge"
    },
    "author": "Playgama",
    "license": "LGPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/playgama/bridge/issues"
    },
    "homepage": "https://github.com/playgama/bridge",
    "devDependencies": {
        "@babel/core": "^7.17.8",
        "@babel/preset-env": "^7.16.11",
        "@types/jsdom": "^21.1.6",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "babel-loader": "^8.2.3",
        "eslint": "^8.55.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-import-resolver-typescript": "^3.10.1",
        "eslint-plugin-sort-class-members": "^1.21.0",
        "eslint-webpack-plugin": "^4.0.1",
        "jsdom": "^24.0.0",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vitest": "^1.6.0",
        "webpack": "^5.70.0",
        "webpack-cli": "^4.9.2",
        "webpack-dev-server": "^4.15.2"
    }
}
